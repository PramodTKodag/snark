SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Set to True ONLY for local development. NEVER in production.
DEBUG=False
WIT_PORT=8100
INTERNAL_PORT=8094
POSTGRES_DB=snark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=snark-postgres
POSTGRES_PORT=5432
REDIS_HOST=snark-redis-cache
REDIS_PORT=6379
REDIS_DB=9

# Comma-separated list of allowed hostnames (optional)
# ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ---- Reverse proxy (only when deployed behind nginx / a load balancer / CDN) ----
# Trust X-Forwarded-Proto so Django recognises HTTPS behind a TLS-terminating
# proxy (prevents an infinite SECURE_SSL_REDIRECT loop). Leave False otherwise.
# USE_PROXY_SSL_HEADER=True
# Number of trusted proxies in front of the app, so per-IP rate limiting reads
# the real client IP from X-Forwarded-For instead of the proxy's address.
# NUM_PROXIES=1

# ---- AI providers (settings are the single source of truth) ----
# Default provider and the fallback order tried on failure/content-filter.
AI_DEFAULT_PROVIDER=groq
AI_PROVIDER_FALLBACK_ORDER=groq,gemini,claude

# Per-provider model ids (override per deployment if needed).
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Groq (free tier — get key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here

# Gemini (optional — free tier if available in your region)
# GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic (optional — requires paid credits)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- CORS ----
# Public API: allow all origins by default. To restrict, set False and list origins.
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ---- Admin panel (opt-in; OFF by default) ----
# Enable the Django admin UI (persona management + dashboard). Off by default so
# public deployments do not expose a login. Put it behind a reverse proxy / IP allowlist.
ADMIN_ENABLED=False
# URL path the admin is mounted at when enabled. CHANGE THIS to a non-guessable
# value for any internet-facing deployment (e.g. manage-a1b2c3/). Keep the trailing slash.
ADMIN_URL=admin/
# Optional: auto-create/update the admin superuser on startup from these vars.
# Leave unset to bootstrap manually with `make admin` (createsuperuser).
# Password must be at least 12 characters.
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-to-a-strong-password
