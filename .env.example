SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Set to True ONLY for local development. NEVER in production.
DEBUG=False
WIT_PORT=8100
INTERNAL_PORT=8094
POSTGRES_DB=snark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=snark-postgres
POSTGRES_PORT=5432
REDIS_HOST=snark-redis-cache
REDIS_PORT=6379
REDIS_DB=9

# Comma-separated list of allowed hostnames (optional)
# ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# AI Provider: "groq" (free), "gemini" (free), or "claude" (paid)
AI_DEFAULT_PROVIDER=groq
AI_DEFAULT_MODEL=llama-3.3-70b-versatile

# Groq (free tier — get key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here

# Gemini (optional — free tier if available in your region)
# GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic (optional — requires paid credits)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
